{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
      // File Layout
      "rootDir": "./src",
      "outDir": "./dist",

      "module": "CommonJS",
      "target": "ES2022",
      "types": ["node"],
      "sourceMap": true,
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "noUncheckedIndexedAccess": true,
      "exactOptionalPropertyTypes": true
  },
  "include": ["src"]
}
